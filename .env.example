# Snowflake connection (JWT key-pair auth) -- copy to .env and fill in.
# See src/snowflake_client.py for the auth implementation.
#
# SNOWFLAKE_ACCOUNT_LOCATOR and SNOWFLAKE_ACCOUNT_URL: run
#   SELECT CURRENT_ACCOUNT();
# in Snowflake to confirm these for your account.
#
# Use a dedicated read-only service account/role for this pipeline, scoped to
# only the tables it needs (see sql/pull_ad_group_daily_performance.sql),
# rather than reusing credentials from another service.

SNOWFLAKE_ACCOUNT_LOCATOR=your_account_locator
SNOWFLAKE_ACCOUNT_URL=your_account_url
SNOWFLAKE_USER=your_service_account_user
SNOWFLAKE_KEY_FILE=/path/to/private_key.p8
SNOWFLAKE_ROLE=your_readonly_role
SNOWFLAKE_WAREHOUSE=your_warehouse
